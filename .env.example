# ──────────────────────────────────────────────────────────────
# Chatbot Rekomendasi Restoran — Environment Configuration
# Copy this file to  .env  and fill in your values.
# ──────────────────────────────────────────────────────────────

# ─── Debug ────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ─── Flask / API ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=5500
API_DEBUG=True
SECRET_KEY=                 # Generate a strong key for production!
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///chatbot.db
SQLALCHEMY_ECHO=False       # Set True to see SQL queries

# ─── Recommendation Engine ────────────────────────────────────
DEFAULT_TOP_N=5
MAX_RECOMMENDATIONS=10
MIN_SIMILARITY_SCORE=0.1

# ─── TF-IDF ──────────────────────────────────────────────────
TFIDF_MAX_FEATURES=5000
TFIDF_MIN_DF=1
TFIDF_MAX_DF=0.95

# ─── Session ─────────────────────────────────────────────────
SESSION_TIMEOUT=7200        # seconds (2 hours)

# ─── Caching ─────────────────────────────────────────────────
MAX_CACHE_SIZE=1000
DATA_UPDATE_INTERVAL=3600   # seconds (1 hour)

# ─── Frontend (Vite — prefix with VITE_ ) ────────────────────
# VITE_API_URL=/api         # Only needed if frontend runs on a different host
# VITE_API_TIMEOUT=10000    # API timeout in ms

# ─── External APIs (future) ──────────────────────────────────
# GOOGLE_MAPS_API_KEY=
# TRIPADVISOR_API_KEY=
